{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hkipo-stock-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-06",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "17 11 * * *"
    ]
  },
  "d1_databases": [
    {
      "binding": "HKIPO_DB",
      "database_name": "your-d1-database-name",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ]
}
